{
  "name": "secop-dashboard",
  "version": "1.0.0",
  "workspaces": ["api", "frontend"],
  "scripts": {
    "dev": "bun dev.ts",
    "build": "bun --cwd frontend run build",
    "start": "docker compose up --build",
    "docker:build": "docker compose build --parallel",
    "docker:push": "docker compose push",
    "docker:release": "bun run docker:build && bun run docker:push"
  }
}
